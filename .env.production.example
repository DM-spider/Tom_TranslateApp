# === 部署模式 ===
DEPLOYMENT_MODE=docker_host_nginx

# === 翻译引擎 API Keys ===
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-flash

BAIDU_APP_ID=
BAIDU_SECRET_KEY=

# === 基础设施 ===
# Docker Compose 内部 Redis 直接用服务名 redis
REDIS_URL=redis://redis:6379/0
# 不要写 localhost。请填写真实数据库主机名或容器服务名
DATABASE_URL=postgresql+asyncpg://translate:change-me@db-host:5432/translate_db
# 若不用 LibreTranslate，可保留默认或留给外部服务地址
LIBRE_TRANSLATE_URL=http://libretranslate-host:5000

# === 应用配置 ===
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=https://tomtranslate.com,https://www.tomtranslate.com,chrome-extension://*
DEBUG=false
NEXT_PUBLIC_API_URL=https://api.tomtranslate.com

# === 安全配置 ===
API_SECRET_KEY=replace-with-random-string
JWT_SECRET_KEY=replace-with-long-random-string
JWT_EXPIRE_DAYS=7

# === 限流配置 ===
RATE_LIMIT_PER_MINUTE=30
FREE_DAILY_PAGE_TRANSLATIONS=10
FREE_DAILY_TEXT_TRANSLATIONS=100