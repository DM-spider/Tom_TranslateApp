# === 部署模式 ===
# local: 本地开发
# docker_host_nginx: Docker 跑后端，宿主机 Nginx 占用 80/443 做反代
# managed: Render / Railway / Fly.io 等托管平台
DEPLOYMENT_MODE=local

# === 翻译引擎 API Keys ===
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-flash

BAIDU_APP_ID=20240101000xxxxx
BAIDU_SECRET_KEY=xxxxxxxxxxxxxxxx

# === 基础设施 ===
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+asyncpg://translate:translate_dev@localhost:5432/translate_db

# === JWT 认证 ===
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_EXPIRE_DAYS=7

# === 应用配置 ===
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,chrome-extension://*
DEBUG=true

# === 安全配置 ===
# 设置后翻译接口需携带 X-API-Key 头，留空则不启用认证（仅本地开发适用）
API_SECRET_KEY=

# === 限流配置 ===
RATE_LIMIT_PER_MINUTE=30
FREE_DAILY_PAGE_TRANSLATIONS=10
FREE_DAILY_TEXT_TRANSLATIONS=100