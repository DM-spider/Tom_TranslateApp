# === 翻译引擎 API Keys ===
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
GEMINI_MODEL=gemini-2.5-flash

BAIDU_APP_ID=
BAIDU_SECRET_KEY=

# === 基础设施（Docker Compose 内部用服务名） ===
REDIS_URL=redis://redis:6379/0
DATABASE_URL=postgresql+asyncpg://translate:translate_prod@db:5432/translate_db
LIBRE_TRANSLATE_URL=http://libretranslate:5000

# === JWT 认证 ===
JWT_SECRET_KEY=replace-with-long-random-string
JWT_EXPIRE_DAYS=7

# === 应用配置 ===
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=https://tomtranslate.com,https://www.tomtranslate.com,chrome-extension://*
DEBUG=false
NEXT_PUBLIC_API_URL=https://api.tomtranslate.com

# === 安全配置 ===
API_SECRET_KEY=

# === 限流配置 ===
RATE_LIMIT_PER_MINUTE=30
FREE_DAILY_PAGE_TRANSLATIONS=10
FREE_DAILY_TEXT_TRANSLATIONS=100

# === 数据库（Docker Compose 用） ===
POSTGRES_USER=translate
POSTGRES_PASSWORD=translate_prod
POSTGRES_DB=translate_db
